    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "ts-node --esm src/cli/index.ts"
  },
  "keywords": ["compiler", "math", "latex", "c-codegen"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
