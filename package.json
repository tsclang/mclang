{
  "name": "mclang",
  "version": "0.1.0",
  "description": "Math C Language — a declarative math computation language that compiles to pure C",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "mclang": "dist/cli/index.js"
  },
  "scripts": {
